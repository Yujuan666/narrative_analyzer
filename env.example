# ── API Keys — copy this file to .env and fill in your keys ──────────────────
# NEVER commit .env to GitHub! It's already in .gitignore.

# Finnhub (free tier: 60 calls/min) → https://finnhub.io
FINNHUB_API_KEY=your_key_here

# Marketaux (free tier: 100 req/day) → https://marketaux.com
MARKETAUX_API_KEY=your_key_here

# NewsAPI (free tier: 100 req/day) → https://newsapi.org
NEWSAPI_KEY=your_key_here

# Alpha Vantage (free tier: 25 req/day) → https://alphavantage.co
ALPHA_VANTAGE_KEY=your_key_here

# Reddit (create a "script" app) → https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
